# Local development credentials — copy this file to .env and fill in your values.
#
# For Vercel deployment: set these same variables in
# Vercel Dashboard → Project → Settings → Environment Variables
# (the CI pipeline pulls them from there; they never need to be in GitHub secrets)

# ── Google Drive Auth ──────────────────────────────────────────────────────────
# Option A: OAuth2 — for personal Google accounts (recommended)
#   1. Go to console.cloud.google.com → APIs & Services → Credentials
#   2. Create credentials → OAuth 2.0 Client ID → Desktop app
#   3. Fill in CLIENT_ID and CLIENT_SECRET below, then run: npm run auth
#      (opens a browser login and saves GOOGLE_REFRESH_TOKEN automatically)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=

# Option B: Service Account — for Google Workspace Shared Drives only
# Personal Gmail accounts cannot use this (service accounts have no Drive storage quota)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Vault / Drive config ───────────────────────────────────────────────────────
# These mirror the values in on-vault.yaml and are used by the build pipeline
# when on-vault.yaml is not present (e.g. on Vercel).
#
# DRIVE_FOLDER_ID: the Google Drive folder ID from the URL when you open the folder
#   drive.google.com/drive/folders/<DRIVE_FOLDER_ID>
DRIVE_FOLDER_ID=your-google-drive-folder-id

# NEXT_PUBLIC_BASE_PATH: URL prefix for your notes (e.g. "docs", "notes", "kb")
# Must match base_path in on-vault.yaml
NEXT_PUBLIC_BASE_PATH=docs

# NEXT_PUBLIC_SITE_TITLE: displayed in the navbar and browser tab
# Must match site.title in on-vault.yaml
NEXT_PUBLIC_SITE_TITLE=My Knowledge Base
