# ── Option A: OAuth2 — for personal Google accounts (recommended) ──────────────
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# → Create credentials → OAuth 2.0 Client ID → Desktop app
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=  # leave blank, filled automatically by: npm run auth

# ── Option B: Service Account — for Google Workspace Shared Drives only ────────
# Personal Gmail accounts cannot use this (no storage quota on service accounts)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
